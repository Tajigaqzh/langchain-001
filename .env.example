# DeepSeek model configuration
# DeepSeek API key.
DEEPSEEK_API_KEY=your_deepseek_api_key
# DeepSeek OpenAI-compatible API base URL.
DEEPSEEK_API_BASE=https://api.deepseek.com
# DeepSeek model name.
DEEPSEEK_MODEL=deepseek-chat
# Shared sampling temperature. Optional.
DEEPSEEK_TEMPERATURE=0.2
# Optional JSON object passed to init_chat_model. Example: {"max_retries": 1}
DEEPSEEK_MODEL_KWARGS={}

# Claude model configuration
# Claude or Claude-compatible API key.
CLAUDE_API_KEY=your_claude_api_key
# Anthropic SDK base URL. Do not include trailing /v1.
CLAUDE_API_BASE=https://api.anthropic.com
# Claude model name.
CLAUDE_MODEL=claude-opus-4-6
# Optional JSON object passed to init_chat_model. Example: {"timeout": 60}
CLAUDE_MODEL_KWARGS={}

# GPT model configuration
# OpenAI or OpenAI-compatible API key.
GPT_API_KEY=your_gpt_api_key
# OpenAI-compatible API base URL.
GPT_API_BASE=https://api.openai.com/v1
# GPT model name.
GPT_MODEL=gpt-5.5
# Optional JSON object passed to init_chat_model. Example: {"max_retries": 1}
GPT_MODEL_KWARGS={}
