# DeepSeek model configuration
# DeepSeek API key.
DEEPSEEK_API_KEY=your_deepseek_api_key
# DeepSeek OpenAI-compatible API base URL.
DEEPSEEK_API_BASE=https://api.deepseek.com
# DeepSeek model name.
DEEPSEEK_MODEL=deepseek-chat
# Shared sampling temperature. Optional.
DEEPSEEK_TEMPERATURE=0.2
# Optional JSON object passed to init_chat_model. Example: {"max_retries": 1}
DEEPSEEK_MODEL_KWARGS={}

# Claude model configuration
# Claude or Claude-compatible API key.
CLAUDE_API_KEY=your_claude_api_key
# Anthropic SDK base URL. Do not include trailing /v1.
CLAUDE_API_BASE=https://api.anthropic.com
# Claude model name.
CLAUDE_MODEL=claude-opus-4-6
# Optional JSON object passed to init_chat_model. Example: {"timeout": 60}
CLAUDE_MODEL_KWARGS={}

# GPT model configuration
# OpenAI or OpenAI-compatible API key.
GPT_API_KEY=your_gpt_api_key
# OpenAI-compatible API base URL.
GPT_API_BASE=https://api.openai.com/v1
# GPT model name.
GPT_MODEL=gpt-5.5
# Optional JSON object passed to init_chat_model. Example: {"max_retries": 1}
GPT_MODEL_KWARGS={}

# CLI behavior
# Default CLI model and session memory settings.
AGENT_DEFAULT_MODEL=gpt-5.5
AGENT_THREAD_ID=default
AGENT_MEMORY_BACKEND=sqlite
AGENT_MEMORY_PATH=.data/agent_memory.sqlite
# SQLite conversation memory retention. Old checkpoints are pruned when the CLI starts.
AGENT_SQLITE_CACHE_DAYS=10
# Retry failed model calls. AGENT_MODEL_RETRY_ATTEMPTS=10 means 1 initial try plus 10 retries.
AGENT_MODEL_RETRY_ATTEMPTS=10
AGENT_MODEL_RETRY_DELAY=3
# Set true to stream Agent output by default. CLI flags --stream/--no-stream override this.
AGENT_STREAM=false
# Smooth streamed output by splitting large provider chunks into smaller flushed chunks.
AGENT_STREAM_CHUNK_SIZE=4
AGENT_STREAM_DELAY=0.015

# Optional MCP tool configuration. Leave empty to disable MCP.
# The file should be JSON and can use either {"mcpServers": {...}} or a direct server mapping.
AGENT_MCP_CONFIG_PATH=
