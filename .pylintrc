[MASTER]
# 指定要检查的 Python 文件或目录
# 可以通过命令行参数覆盖
init-hook='import sys; sys.path.append(".")'

# 使用多进程加速检查
jobs=0

# 忽略的文件或目录模式
ignore=CVS,.git,__pycache__,.pytest_cache,.codegraph,venv,env

# 忽略的目录模式（相对路径）
ignore-paths=^\..*,^venv/.*,^env/.*

[MESSAGES CONTROL]
# 禁用的检查项
disable=
    C0111,  # missing-docstring
    C0103,  # invalid-name (允许单字母变量名)
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    W0212,  # protected-access
    R0801,  # duplicate-code (在测试中常见)
    W0511,  # fixme (允许 TODO/FIXME 注释)
    E1101,  # no-member (LangChain 动态属性较多)
    R0914,  # too-many-locals
    R0915,  # too-many-statements
    C0302,  # too-many-lines

# 启用的检查项（可选，显式列出重要的检查）
enable=
    E,      # 错误
    F,      # 致命错误
    W,      # 警告
    C,      # 约定
    R,      # 重构建议

[REPORTS]
# 输出格式
output-format=colorized

# 报告评分
score=yes

[BASIC]
# 命名规范
# 函数和变量：snake_case
function-naming-style=snake_case
variable-naming-style=snake_case

# 类：PascalCase
class-naming-style=PascalCase

# 常量：UPPER_SNAKE_CASE
const-naming-style=UPPER_CASE

# 方法：snake_case
method-naming-style=snake_case

# 参数：snake_case
argument-naming-style=snake_case

# 属性：snake_case
attr-naming-style=snake_case

# 允许的单字母变量名
good-names=i,j,k,ex,_,id,x,y,z,df,ax,fig

[FORMAT]
# 最大行长度
max-line-length=120

# 每行最大参数数量
max-args=7

# 每个类最大属性数量
max-attributes=10

# 缩进字符串
indent-string='    '

# 期望的缩进
indent-after-paren=4

[DESIGN]
# 最大参数数量
max-args=7

# 最大局部变量数量
max-locals=20

# 最大返回语句数量
max-returns=6

# 最大分支数量
max-branches=15

# 最大语句数量
max-statements=60

# 最小公共方法数量
min-public-methods=1

# 最大公共方法数量
max-public-methods=25

[IMPORTS]
# 已弃用的模块
deprecated-modules=optparse

[EXCEPTIONS]
# 允许捕获的异常类型
overgeneral-exceptions=builtins.Exception

[TYPECHECK]
# 忽略缺失成员的模块
ignored-modules=

# 忽略的类
ignored-classes=SQLObject

# 生成成员的函数
generated-members=

[SIMILARITIES]
# 最小相似行数触发重复代码警告
min-similarity-lines=10

# 忽略注释
ignore-comments=yes

# 忽略文档字符串
ignore-docstrings=yes

# 忽略导入语句
ignore-imports=yes
